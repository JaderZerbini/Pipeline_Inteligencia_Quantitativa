# Telegram — obtenha via @BotFather no Telegram
# Para múltiplos destinos, separe por vírgula: 111111,222222
TELEGRAM_TOKEN=seu_token_aqui
TELEGRAM_CHAT_ID=seu_chat_id_aqui

# Google Gemini — fallback quando OpenRouter falha
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua_gemini_key_aqui

# OpenRouter — consenso 3 modelos (Qwen 2.5 + Llama 3.3 + Gemini 2.5)
# Obtenha em: https://openrouter.ai/keys
OPENROUTER_API_KEY=sua_openrouter_key_aqui

# Parâmetros opcionais (valores padrão abaixo)
# Stop loss como decimal: 0.07 = 7%
STOP_LOSS_PCT=0.07
# Take profit como decimal: 0.15 = 15%
GAIN_TARGET_PCT=0.15
# Intervalo entre varreduras em minutos
SCAN_INTERVAL_MINUTES=30
